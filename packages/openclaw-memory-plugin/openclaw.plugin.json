{
  "id": "youarememory-openclaw",
  "name": "YouAreMemory OpenClaw Plugin",
  "description": "Multi-level memory plugin (L0/L1/L2) with local-first SQLite and ChatGPT-style UI.",
  "version": "0.1.0",
  "kind": "memory",
  "main": "./dist/index.js",
  "skills": [
    "agent-skills"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dataDir": {
        "type": "string",
        "description": "Base directory used to persist local memory data."
      },
      "dbPath": {
        "type": "string",
        "description": "Absolute path to sqlite file. Overrides dataDir."
      },
      "skillsDir": {
        "type": "string",
        "description": "Optional custom path for skills JSON/MD files."
      },
      "captureStrategy": {
        "type": "string",
        "enum": [
          "last_turn",
          "full_session"
        ],
        "default": "full_session"
      },
      "includeAssistant": {
        "type": "boolean",
        "default": true
      },
      "maxMessageChars": {
        "type": "integer",
        "default": 6000
      },
      "heartbeatBatchSize": {
        "type": "integer",
        "default": 30
      },
      "autoIndexIntervalMinutes": {
        "type": "integer",
        "default": 60
      },
      "recallBudgetMs": {
        "type": "integer",
        "default": 700
      },
      "indexIdleDebounceMs": {
        "type": "integer",
        "default": 2500
      },
      "fastRecallFallbackEnabled": {
        "type": "boolean",
        "default": true
      },
      "recallEnabled": {
        "type": "boolean",
        "default": true
      },
      "addEnabled": {
        "type": "boolean",
        "default": true
      },
      "uiEnabled": {
        "type": "boolean",
        "default": true
      },
      "uiHost": {
        "type": "string",
        "default": "127.0.0.1"
      },
      "uiPort": {
        "type": "integer",
        "default": 39393
      },
      "uiPathPrefix": {
        "type": "string",
        "default": "/youarememory"
      }
    }
  },
  "uiHints": {
    "dbPath": {
      "label": "SQLite Path",
      "placeholder": "~/.openclaw/youarememory/memory.sqlite"
    },
    "skillsDir": {
      "label": "Skills Directory",
      "placeholder": "~/.openclaw/youarememory/skills"
    },
    "captureStrategy": {
      "label": "Capture Strategy",
      "help": "full_session is retained as a fallback source, but indexing now closes L1 on topic shift instead of time/count windows."
    },
    "autoIndexIntervalMinutes": {
      "label": "Auto Index Interval",
      "placeholder": "60"
    },
    "recallBudgetMs": {
      "label": "Recall Budget (ms)",
      "placeholder": "700"
    },
    "indexIdleDebounceMs": {
      "label": "Idle Index Delay (ms)",
      "placeholder": "2500"
    },
    "fastRecallFallbackEnabled": {
      "label": "Fallback On Timeout",
      "help": "When the fast memory selector times out, inject local profile/L2 memory instead of blocking the main reply."
    },
    "uiEnabled": {
      "label": "Enable Local UI",
      "help": "Start local read-only dashboard server for timeline/project/profile memory."
    },
    "uiPort": {
      "label": "UI Port",
      "placeholder": "39393"
    }
  }
}
