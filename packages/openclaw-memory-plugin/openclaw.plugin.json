{
  "id": "youarememory-openclaw",
  "name": "YouAreMemory OpenClaw Plugin",
  "description": "Multi-level memory plugin (L0/L1/L2) with local-first SQLite and ChatGPT-style UI.",
  "version": "0.1.0",
  "kind": "memory",
  "main": "./dist/index.js",
  "skills": [
    "agent-skills"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dataDir": {
        "type": "string",
        "description": "Base directory used to persist local memory data."
      },
      "dbPath": {
        "type": "string",
        "description": "Absolute path to sqlite file. Overrides dataDir."
      },
      "skillsDir": {
        "type": "string",
        "description": "Optional custom path for skills JSON/MD files."
      },
      "captureStrategy": {
        "type": "string",
        "enum": [
          "last_turn",
          "full_session"
        ],
        "default": "full_session"
      },
      "includeAssistant": {
        "type": "boolean",
        "default": true
      },
      "maxMessageChars": {
        "type": "integer",
        "default": 6000
      },
      "heartbeatBatchSize": {
        "type": "integer",
        "default": 30
      },
      "autoIndexIntervalMinutes": {
        "type": "integer",
        "default": 60
      },
      "l1WindowMode": {
        "type": "string",
        "enum": [
          "time",
          "count"
        ],
        "default": "time"
      },
      "l1WindowMinutes": {
        "type": "integer",
        "default": 120
      },
      "l1WindowMaxL0": {
        "type": "integer",
        "default": 8
      },
      "l2TimeGranularity": {
        "type": "string",
        "enum": [
          "day",
          "half_day",
          "hour"
        ],
        "default": "day"
      },
      "recallEnabled": {
        "type": "boolean",
        "default": true
      },
      "addEnabled": {
        "type": "boolean",
        "default": true
      },
      "uiEnabled": {
        "type": "boolean",
        "default": true
      },
      "uiHost": {
        "type": "string",
        "default": "127.0.0.1"
      },
      "uiPort": {
        "type": "integer",
        "default": 39393
      },
      "uiPathPrefix": {
        "type": "string",
        "default": "/youarememory"
      }
    }
  },
  "uiHints": {
    "dbPath": {
      "label": "SQLite Path",
      "placeholder": "~/.openclaw/youarememory/memory.sqlite"
    },
    "skillsDir": {
      "label": "Skills Directory",
      "placeholder": "~/.openclaw/youarememory/skills"
    },
    "captureStrategy": {
      "label": "Capture Strategy",
      "help": "full_session is retained as a fallback source, but indexing now batches L0s into session windows before building L1/L2."
    },
    "autoIndexIntervalMinutes": {
      "label": "Auto Index Interval",
      "placeholder": "60"
    },
    "l1WindowMode": {
      "label": "L1 Window Mode",
      "help": "Choose either time-based windows or count-based windows for L1 construction."
    },
    "l1WindowMinutes": {
      "label": "L1 Window Minutes",
      "placeholder": "120"
    },
    "l1WindowMaxL0": {
      "label": "L1 Max L0 Count",
      "placeholder": "8"
    },
    "l2TimeGranularity": {
      "label": "L2 Time Granularity",
      "help": "Choose whether L2 time indexes aggregate by day, half-day, or hour."
    },
    "uiEnabled": {
      "label": "Enable Local UI",
      "help": "Start local read-only dashboard server for timeline/project/facts."
    },
    "uiPort": {
      "label": "UI Port",
      "placeholder": "39393"
    }
  }
}
