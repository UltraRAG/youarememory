{
  "id": "youarememory-openclaw",
  "name": "YouAreMemory OpenClaw Plugin",
  "description": "Multi-level memory plugin (L0/L1/L2) with local-first SQLite and ChatGPT-style UI.",
  "version": "0.1.0",
  "kind": "memory",
  "main": "./dist/index.js",
  "skills": [
    "agent-skills"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "dataDir": {
        "type": "string",
        "description": "Base directory used to persist local memory data."
      },
      "dbPath": {
        "type": "string",
        "description": "Absolute path to sqlite file. Overrides dataDir."
      },
      "skillsDir": {
        "type": "string",
        "description": "Optional custom path for skills JSON/MD files."
      },
      "captureStrategy": {
        "type": "string",
        "enum": [
          "last_turn",
          "full_session"
        ],
        "default": "full_session"
      },
      "includeAssistant": {
        "type": "boolean",
        "default": true
      },
      "maxMessageChars": {
        "type": "integer",
        "default": 6000
      },
      "heartbeatBatchSize": {
        "type": "integer",
        "default": 30
      },
      "autoIndexIntervalMinutes": {
        "type": "integer",
        "default": 60
      },
      "reasoningMode": {
        "type": "string",
        "enum": [
          "answer_first",
          "accuracy_first"
        ],
        "default": "answer_first"
      },
      "maxAutoReplyLatencyMs": {
        "type": "integer",
        "default": 1800
      },
      "recallBudgetMs": {
        "type": "integer",
        "default": 1800
      },
      "indexIdleDebounceMs": {
        "type": "integer",
        "default": 2500
      },
      "fastRecallFallbackEnabled": {
        "type": "boolean",
        "default": true
      },
      "recallEnabled": {
        "type": "boolean",
        "default": true
      },
      "addEnabled": {
        "type": "boolean",
        "default": true
      },
      "uiEnabled": {
        "type": "boolean",
        "default": true
      },
      "uiHost": {
        "type": "string",
        "default": "127.0.0.1"
      },
      "uiPort": {
        "type": "integer",
        "default": 39393
      },
      "uiPathPrefix": {
        "type": "string",
        "default": "/youarememory"
      }
    }
  },
  "uiHints": {
    "dbPath": {
      "label": "SQLite Path",
      "placeholder": "~/.openclaw/youarememory/memory.sqlite"
    },
    "skillsDir": {
      "label": "Skills Directory",
      "placeholder": "~/.openclaw/youarememory/skills"
    },
    "captureStrategy": {
      "label": "Capture Strategy",
      "help": "full_session is retained as a fallback source, but indexing now closes L1 on topic shift instead of time/count windows."
    },
    "autoIndexIntervalMinutes": {
      "label": "Auto Index Interval",
      "placeholder": "60"
    },
    "reasoningMode": {
      "label": "Reasoning Mode",
      "help": "answer_first stops when reply latency budget is about to run out; accuracy_first prefers full recursive memory retrieval."
    },
    "maxAutoReplyLatencyMs": {
      "label": "Max Auto Reply Latency (ms)",
      "placeholder": "1800"
    },
    "uiEnabled": {
      "label": "Enable Local UI",
      "help": "Start local read-only dashboard server for timeline/project/profile memory."
    },
    "uiPort": {
      "label": "UI Port",
      "placeholder": "39393"
    }
  }
}
